# Gradle
.gradle/
build/
out/
local.properties

# Android Studio / IntelliJ
.idea/
*.iml
captures/

# Build outputs
app/build/
app/release/

# Drive setup — never commit OAuth/Firebase configs.
# This app does not need google-services.json (see GOOGLE_CLOUD_SETUP.md),
# but ignore it defensively in case Firebase is added later.
app/google-services.json

# Keystores & signing
*.jks
*.keystore
keystore.properties

# Android Developer Verification (ADI) registration token. Ties the
# developer's Google identity to APK builds of this app — same
# sensitivity class as keystore.properties. Each maintainer needs
# their own copy at app/src/main/assets/adi-registration.properties
# (one line, the raw snippet from the Google verification page);
# CI release.yml needs the same value via a GitHub Secret if the
# CI-built APK should also be registered.
app/src/main/assets/adi-registration.properties

# OS noise
.DS_Store
Thumbs.db

# Roborazzi screenshot test artefacts (TASK-35).
# Only the canonical baselines under app/src/test/screenshots/ are tracked;
# Roborazzi writes the actual + diff PNGs alongside on a failed verify.
app/src/test/screenshots/*.actual.png
app/src/test/screenshots/*.diff.png
app/src/test/screenshots/*_actual.png
app/src/test/screenshots/*_diff.png
app/build/outputs/roborazzi/
