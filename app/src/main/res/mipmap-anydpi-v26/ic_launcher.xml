<?xml version="1.0" encoding="utf-8"?>
<!-- Adaptive launcher icon (Android 8+).
     - background: solid Joulie brand blue tile
     - foreground: gradient bolt-J (PNG raster, lives in mipmap-{m,h,xh,xxh,xxxh}dpi)
     - monochrome: single-colour bolt for Android 13+ "Themed icons"
       (the OS tints this drawable to match the user's wallpaper). -->
<adaptive-icon xmlns:android="http://schemas.android.com/apk/res/android">
    <background android:drawable="@color/joulie_brand_blue"/>
    <foreground android:drawable="@mipmap/ic_launcher_foreground"/>
    <monochrome android:drawable="@drawable/ic_launcher_monochrome"/>
</adaptive-icon>
