<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Joulie brand palette (docs/branding/brand_palette.png):
         #0D47FF vibrant blue · #00C2D1 teal · #A6F43C green · #FFD54D yellow.
         M3 tone ramps below are derived from these seeds; they are an
         approximation of Material Theme Builder output and should be
         regenerated through MTB if pixel-precise tokens are required. -->

    <!-- Adaptive launcher-icon background: solid Joulie brand blue.
         Referenced from mipmap-anydpi-v26/ic_launcher{,_round}.xml so
         Android 8+ shows the logo on a brand-blue tile. The legacy
         (pre-O) ic_launcher.png mipmaps render the logo on white per
         the master ic_launcher_512.png. -->
    <color name="joulie_brand_blue">#0D47FF</color>

    <!-- M3 — Primary (seeded #0D47FF — Joulie vibrant blue) -->
    <color name="md_theme_light_primary">#1F3DCC</color>
    <color name="md_theme_light_onPrimary">#FFFFFF</color>
    <color name="md_theme_light_primaryContainer">#DCE1FF</color>
    <color name="md_theme_light_onPrimaryContainer">#001255</color>

    <!-- M3 — Secondary (seeded #00C2D1 — Joulie teal) -->
    <color name="md_theme_light_secondary">#006874</color>
    <color name="md_theme_light_onSecondary">#FFFFFF</color>
    <color name="md_theme_light_secondaryContainer">#9EEFFD</color>
    <color name="md_theme_light_onSecondaryContainer">#001F24</color>

    <!-- M3 — Tertiary (seeded #FFD54D — Joulie yellow; replaces the
         pre-rebrand "DC orange" #FB8C00 ramp). DC chart series and the
         provenance "Est." badge surface in this ramp. -->
    <color name="md_theme_light_tertiary">#7F5700</color>
    <color name="md_theme_light_onTertiary">#FFFFFF</color>
    <color name="md_theme_light_tertiaryContainer">#FFE082</color>
    <color name="md_theme_light_onTertiaryContainer">#281900</color>

    <!-- M3 — Error -->
    <color name="md_theme_light_error">#BA1A1A</color>
    <color name="md_theme_light_onError">#FFFFFF</color>
    <color name="md_theme_light_errorContainer">#FFDAD6</color>
    <color name="md_theme_light_onErrorContainer">#410002</color>

    <!-- M3 — Neutral / surface -->
    <color name="md_theme_light_background">#FDFCFF</color>
    <color name="md_theme_light_onBackground">#1A1C1E</color>
    <color name="md_theme_light_surface">#FDFCFF</color>
    <color name="md_theme_light_onSurface">#1A1C1E</color>
    <color name="md_theme_light_surfaceVariant">#DFE2EB</color>
    <color name="md_theme_light_onSurfaceVariant">#43474E</color>
    <color name="md_theme_light_outline">#73777F</color>
    <color name="md_theme_light_outlineVariant">#C3C7CF</color>

    <!-- M3 — Inverse + scrim -->
    <color name="md_theme_light_inverseSurface">#2F3033</color>
    <color name="md_theme_light_inverseOnSurface">#F1F0F4</color>
    <color name="md_theme_light_inversePrimary">#B7C4FF</color>
    <color name="md_theme_light_scrim">#000000</color>

    <!-- Chart palette (non-theme product colors). chart_1 anchors on
         the Joulie primary blue; chart_2/3/4/5 are visually-distinct
         hues retained for series ≥ 2. -->
    <color name="chart_1">#0D47FF</color>
    <color name="chart_2">#00C2D1</color>
    <color name="chart_3">#FFD54D</color>
    <color name="chart_4">#A6F43C</color>
    <color name="chart_5">#6A1B9A</color>

    <!-- Chart series fallback colors. Used only when theme attrs
         (?attr/colorPrimary, ?attr/colorTertiary) cannot be resolved.
         AC = primary blue, DC = tertiary yellow. -->
    <color name="chart_ac_fallback">#0D47FF</color>
    <color name="chart_dc_fallback">#FFD54D</color>

    <!-- Defensive fallbacks for chart axis text and gridlines. Used only
         when ?attr/colorOnSurface and ?attr/colorOutlineVariant cannot
         be resolved (which the M3 theme always provides). -->
    <color name="chart_axis_text_fallback">#1C1B1F</color>
    <color name="chart_axis_grid_fallback">#79747E</color>

    <!-- Brand-pack v1.0 additions (Brand Guide §3 Palette).
         joulie_ink_deep is the wordmark colour on light surfaces (avoid
         pure black). joulie_spark_green is the accent for the SPS-Lab
         credit and "fresh" affordances; aligned with chart_4. -->
    <color name="joulie_ink_deep">#0A1B5E</color>
    <color name="joulie_spark_green">#A6F43C</color>
</resources>
