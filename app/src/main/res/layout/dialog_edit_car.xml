<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:id="@+id/car_dialog_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:textAppearance="?attr/textAppearanceHeadlineSmall"
            tools:text="@string/car_dialog_add_title"/>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/car_dialog_name_layout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/car_form_name">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/car_dialog_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textCapWords"/>
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Make + Model use an inline suggestion list rendered in
             this same view tree (v1.13.6 fix). v1.13.0..v1.13.5
             cycled through every (widget × dialog host) combination
             of AutoCompleteTextView / MaterialAutoCompleteTextView
             inside MaterialAlertDialog / BottomSheetDialog; the
             popup window never rendered on the user's Pixel 6a in
             any combination. The inline-list approach renders the
             filtered matches as plain TextViews inside the same
             scrollable bottom-sheet content, so no PopupWindow is
             involved and the rendering is independent of dialog /
             window-layer behaviour. -->
        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/car_form_make"
            app:helperText="@string/car_form_make_helper">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/car_dialog_make"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textCapWords"
                android:imeOptions="actionNext"/>
        </com.google.android.material.textfield.TextInputLayout>

        <LinearLayout
            android:id="@+id/car_dialog_make_suggestions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            android:layout_marginTop="4dp"
            android:background="@drawable/bg_suggestion_list"
            tools:ignore="UseCompoundDrawables"/>

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/car_form_model"
            app:helperText="@string/car_form_model_helper">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/car_dialog_model"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textCapWords"
                android:imeOptions="actionNext"/>
        </com.google.android.material.textfield.TextInputLayout>

        <LinearLayout
            android:id="@+id/car_dialog_model_suggestions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            android:layout_marginTop="4dp"
            android:background="@drawable/bg_suggestion_list"
            tools:ignore="UseCompoundDrawables"/>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/car_form_year">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/car_dialog_year"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="number"/>
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/car_form_battery_kwh">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/car_dialog_battery"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="numberDecimal"/>
        </com.google.android.material.textfield.TextInputLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="end"
            android:layout_marginTop="16dp">
            <com.google.android.material.button.MaterialButton
                android:id="@+id/car_dialog_cancel"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:text="@string/car_dialog_cancel"/>
            <com.google.android.material.button.MaterialButton
                android:id="@+id/car_dialog_save"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/car_dialog_save"/>
        </LinearLayout>

    </LinearLayout>

</androidx.core.widget.NestedScrollView>
