<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="?attr/selectableItemBackground"
    android:orientation="vertical"
    android:padding="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/item_charge_date"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textAppearance="?attr/textAppearanceTitleSmall"
            tools:text="27 Apr 2026, 12:34"/>

        <!-- "Est." badge for events flagged DERIVED_FROM_SOC. Tertiary-
             container colour distinguishes the provenance from the AC/DC
             charge-type badge that sits beside it. -->
        <TextView
            android:id="@+id/item_charge_estimated_badge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="4dp"
            android:background="?attr/colorTertiaryContainer"
            android:contentDescription="@string/history_kwh_estimated_badge_content_desc"
            android:paddingHorizontal="8dp"
            android:paddingVertical="2dp"
            android:text="@string/history_kwh_estimated_badge"
            android:textColor="?attr/colorOnTertiaryContainer"
            android:textAppearance="?attr/textAppearanceLabelSmall"
            android:visibility="gone"
            tools:visibility="visible"/>

        <TextView
            android:id="@+id/item_charge_type_badge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="?attr/colorSecondaryContainer"
            android:paddingHorizontal="8dp"
            android:paddingVertical="2dp"
            android:textColor="?attr/colorOnSecondaryContainer"
            android:textAppearance="?attr/textAppearanceLabelSmall"
            tools:text="AC"/>
    </LinearLayout>

    <TextView
        android:id="@+id/item_charge_summary"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textAppearance="?attr/textAppearanceBodyMedium"
        tools:text="123,456 km · 22.4 kWh"/>

    <TextView
        android:id="@+id/item_charge_location"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textAppearance="?attr/textAppearanceBodySmall"
        android:visibility="gone"
        tools:text="Home"
        tools:visibility="visible"/>

    <TextView
        android:id="@+id/item_charge_cost"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textAppearance="?attr/textAppearanceLabelMedium"
        android:visibility="gone"
        tools:text="€5.50"
        tools:visibility="visible"/>

    <TextView
        android:id="@+id/item_charge_note"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:singleLine="true"
        android:textAppearance="?attr/textAppearanceBodySmall"
        android:visibility="gone"/>

</LinearLayout>
