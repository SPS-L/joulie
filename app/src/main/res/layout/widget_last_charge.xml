<?xml version="1.0" encoding="utf-8"?>
<!--
    — home-screen widget for the most recent charge of the active car.
    RemoteViews-only — no custom views, no fragment, no data binding.
    The provider hides the "loaded" group + shows the empty TextView when
    there is no active car or no events.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="12dp"
    android:background="@drawable/widget_background">

    <TextView
        android:id="@+id/widget_empty"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:textSize="14sp"
        android:visibility="gone"
        tools:text="No charges logged yet."/>

    <LinearLayout
        android:id="@+id/widget_loaded"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">
            <ImageView
                android:id="@+id/widget_charge_icon"
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_marginEnd="6dp"
                android:contentDescription="@string/widget_charge_type_content_description"
                android:src="@drawable/ic_widget_bolt"/>
            <TextView
                android:id="@+id/widget_car_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="15sp"
                android:textStyle="bold"
                android:singleLine="true"
                android:ellipsize="end"
                tools:text="Tesla Model 3"/>
        </LinearLayout>

        <TextView
            android:id="@+id/widget_relative_date"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textSize="11sp"
            tools:text="Yesterday"/>

        <TextView
            android:id="@+id/widget_kwh"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:textSize="13sp"
            tools:text="42.0 kWh added"/>

        <TextView
            android:id="@+id/widget_efficiency"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            tools:text="6.2 km/kWh"/>

        <TextView
            android:id="@+id/widget_cost"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:visibility="gone"
            tools:text="€12.50"/>
    </LinearLayout>
</LinearLayout>
