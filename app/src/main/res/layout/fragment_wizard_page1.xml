<?xml version="1.0" encoding="utf-8"?>
<!-- Redesigned wizard welcome (page 1).
     Top half: branded gradient panel with the bolt-J + wordmark
     (drawable/wizard_hero copied from the brand pack).
     Bottom half: white surface card with the welcome body + the
     language picker row pinned to the bottom.

     This makes the first-run experience feel like a real product hero
     instead of plain text on a blank background. -->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Hero banner — covers the top ~55% of the page on phones, with
         the wordmark and tagline baked into the artwork.
         Fallback colour: bg_brand_gradient (so the page is still branded
         even if the PNG is missing). -->
    <ImageView
        android:id="@+id/wizard_page1_hero"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:scaleType="centerCrop"
        android:contentDescription="@string/wizard_welcome_title"
        android:background="@drawable/bg_brand_gradient"
        android:src="@drawable/wizard_hero"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/wizard_page1_card"
        app:layout_constraintHeight_percent="0.52"/>

    <!-- Lower card — sits flush over the gradient with a rounded top,
         so the hero appears to "tuck behind" the body content. -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/wizard_page1_card"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:cardCornerRadius="28dp"
        app:cardElevation="0dp"
        app:cardBackgroundColor="?attr/colorSurface"
        android:layout_marginTop="-32dp"
        app:layout_constraintTop_toBottomOf="@id/wizard_page1_hero"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="32dp"
            android:gravity="top">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_horizontal"
                android:text="@string/wizard_page1_intro_title"
                android:textAppearance="?attr/textAppearanceTitleLarge"
                android:textColor="?attr/colorOnSurface"/>

            <TextView
                android:id="@+id/wizard_page1_body"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:gravity="center_horizontal"
                android:text="@string/wizard_welcome_body"
                android:textAppearance="?attr/textAppearanceBodyMedium"
                android:textColor="?attr/colorOnSurfaceVariant"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"/>

            <!-- Language picker row, kept on page 1 so a Greek-speaking
                 user with an English-defaulted phone can switch without
                 reading English first. Now styled as a tonal row. -->
            <LinearLayout
                android:id="@+id/wizard_page1_language_row"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="16dp"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/wizard_language_label"
                        android:textAppearance="?attr/textAppearanceLabelMedium"
                        android:textColor="?attr/colorPrimary"/>
                    <TextView
                        android:id="@+id/wizard_page1_language_value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textAppearance="?attr/textAppearanceBodyLarge"
                        tools:text="English"/>
                </LinearLayout>

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_arrow_back_24"
                    android:rotation="180"
                    android:contentDescription="@null"
                    app:tint="?attr/colorOnSurfaceVariant"/>

            </LinearLayout>

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>
